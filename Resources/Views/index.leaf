<!doctype html>
<html lang="en">
<head>
    <title>#(title)</title>
</head>

<body>
    <h1>#(title)</h1>
    <button onclick="createGame()">Host Game</button>
    
    <input type="text" id="username" placeholder="Enter username" />
    <button onclick="createPlayer()">Set username</button>

    <script>
        async function createGame() {
            const response = await fetch("/sessions/create", {
                method: "POST"
            })
            
            const session = await response.json()
            
            window.location.href = "/games/" + session.id
        }
        
        async function createPlayer() {
            const response = await fetch("/players/create", {
                method: "POST"
            })
            
            const player = await response.json()
        }
    </script>
</body>
</html>
