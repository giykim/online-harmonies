<!doctype html>
<html lang="en">
<head>
    <title>#(title)</title>
</head>

<body>
    <h1>#(title)</h1>
    <button onclick="createGame()">Host Game</button>

    #for(token in tokens):
        <p>
            ID: #(token.id) | Game Session Id: #(token.gameSession.id) | Color: #(token.color) | Space Type: #(token.spaceType) | Space ID: #(token.spaceId)
        </p>
    #endfor

    <script>
        async function createGame() {
            const response = await fetch("/sessions/create", {
                method: "POST",
            })
            
            const session = await response.json()
            
            window.location.href = "/game/" + session.id
        }
    </script>
</body>
</html>
